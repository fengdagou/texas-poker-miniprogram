/* 美女荷官组件样式 */

.dealer-container {
  position: fixed;
  bottom: 20rpx;
  right: 20rpx;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dealer-avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  border: 4rpx solid #ffd700;
  overflow: hidden;
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.dealer-image {
  width: 100%;
  height: 100%;
}

/* 说话动画 */
.dealer-speak-indicator {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.speak-wave {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 3rpx solid rgba(255, 215, 0, 0.6);
  animation: wave 1.5s ease-out infinite;
}

.wave-1 {
  width: 100%;
  height: 100%;
  animation-delay: 0s;
}

.wave-2 {
  width: 120%;
  height: 120%;
  animation-delay: 0.3s;
}

.wave-3 {
  width: 140%;
  height: 140%;
  animation-delay: 0.6s;
}

@keyframes wave {
  0% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(0.8);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(1.2);
  }
}

/* 对话框 */
.dealer-dialog {
  margin-bottom: 20rpx;
  animation: slideUp 0.3s ease-out;
}

.dealer-bubble {
  background: white;
  padding: 20rpx 30rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  position: relative;
  max-width: 400rpx;
}

.dealer-bubble::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid white;
}

.dealer-bubble text {
  font-size: 28rpx;
  color: #333;
}

/* 控制按钮 */
.dealer-controls {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  margin-top: 10rpx;
}

.control-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.control-btn:active {
  background: rgba(255, 215, 0, 0.9);
}

.icon {
  font-size: 32rpx;
}

/* 动画 */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
