/* pages/index/index.wxss - 古典风格 */

.container {
  min-height: 100vh;
  background: 
    repeating-linear-gradient(
      90deg,
      rgba(139, 69, 19, 0.08) 0px,
      rgba(139, 69, 19, 0.08) 2px,
      transparent 2px,
      transparent 4px
    ),
    linear-gradient(135deg, #2c1810 0%, #1a0f0a 50%, #2c1810 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 古典边框装饰 */
.container::before {
  content: '';
  position: fixed;
  top: 15rpx;
  left: 15rpx;
  right: 15rpx;
  bottom: 15rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.25);
  border-radius: 25rpx;
  pointer-events: none;
  z-index: 1;
}

/* 角落装饰花纹 */
.container::after {
  content: '♠ ♥ ♦ ♣';
  position: fixed;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(212, 175, 55, 0.15);
  font-size: 36rpx;
  letter-spacing: 20rpx;
  pointer-events: none;
  z-index: 1;
}

.header {
  text-align: center;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 5;
}

.title {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 
    0 4rpx 20rpx rgba(255, 215, 0, 0.5),
    0 0 40rpx rgba(212, 175, 55, 0.3);
  font-family: 'Georgia', serif;
  letter-spacing: 10rpx;
}

.subtitle {
  font-size: 30rpx;
  color: #d4af37;
  margin-top: 15rpx;
  font-style: italic;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
  font-family: 'Georgia', serif;
}

.coins-panel {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
  border-radius: 35rpx;
  padding: 35rpx 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
  box-shadow: 
    0 10rpx 40rpx rgba(0, 0, 0, 0.5),
    inset 0 2rpx 15rpx rgba(212, 175, 55, 0.1);
  border: 3rpx solid rgba(212, 175, 55, 0.4);
  position: relative;
  z-index: 5;
}

.coins-icon {
  font-size: 56rpx;
  margin-right: 25rpx;
  text-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.5);
}

.coins-amount {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 0 2rpx 15rpx rgba(255, 215, 0, 0.4);
  font-family: 'Georgia', serif;
}

.coins-label {
  font-size: 30rpx;
  color: #f0c850;
  margin-left: 15rpx;
  font-weight: bold;
}

.game-modes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 25rpx;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 5;
}

.mode-card {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.7) 0%, rgba(44, 24, 16, 0.85) 100%);
  border-radius: 28rpx;
  padding: 45rpx 25rpx;
  text-align: center;
  border: 2rpx solid rgba(212, 175, 55, 0.25);
  box-shadow: 
    0 8rpx 30rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 15rpx rgba(212, 175, 55, 0.08);
  transition: all 0.35s ease;
}

.mode-card:active {
  transform: scale(0.96) translateY(3rpx);
  border-color: rgba(212, 175, 55, 0.5);
  box-shadow: 
    0 4rpx 15rpx rgba(0, 0, 0, 0.3),
    inset 0 2rpx 10rpx rgba(212, 175, 55, 0.15);
}

.mode-icon {
  font-size: 70rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
}

.mode-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.3);
  font-family: 'Georgia', serif;
}

.mode-desc {
  font-size: 26rpx;
  color: #d4af37;
  opacity: 0.8;
}

.footer {
  text-align: center;
  color: #8b6f5a;
  font-size: 26rpx;
  position: relative;
  z-index: 5;
}

.version {
  color: #6b5345;
  font-style: italic;
}

/* 弹窗样式 - 古典风格 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 15, 10, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: linear-gradient(135deg, #2c1810 0%, #1a0f0a 50%, #2c1810 100%);
  border-radius: 35rpx;
  padding: 55rpx;
  width: 85%;
  max-width: 650rpx;
  border: 4rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: 
    0 20rpx 60rpx rgba(0, 0, 0, 0.7),
    inset 0 0 40rpx rgba(139, 69, 19, 0.2);
  position: relative;
}

/* 古典角饰 */
.modal-content::before {
  content: '♦';
  position: absolute;
  top: 15rpx;
  left: 15rpx;
  color: rgba(212, 175, 55, 0.25);
  font-size: 45rpx;
}

.modal-content::after {
  content: '♥';
  position: absolute;
  bottom: 15rpx;
  right: 15rpx;
  color: rgba(212, 175, 55, 0.25);
  font-size: 45rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
  text-align: center;
  margin-bottom: 45rpx;
  text-shadow: 0 2rpx 15rpx rgba(212, 175, 55, 0.4);
  font-family: 'Georgia', serif;
  letter-spacing: 5rpx;
}

.room-input {
  background: linear-gradient(135deg, rgba(44, 24, 16, 0.8) 0%, rgba(26, 15, 10, 0.9) 100%);
  border-radius: 20rpx;
  padding: 30rpx 35rpx;
  font-size: 36rpx;
  color: #ffd700;
  text-align: center;
  letter-spacing: 12rpx;
  margin-bottom: 45rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.3);
  box-shadow: 
    inset 0 4rpx 20rpx rgba(0, 0, 0, 0.5),
    0 2rpx 10rpx rgba(0, 0, 0, 0.3);
  font-family: 'Georgia', serif;
}

.room-input::placeholder {
  color: #6b5345;
}

.modal-buttons {
  display: flex;
  gap: 25rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  padding: 28rpx;
  border-radius: 22rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  box-shadow: 
    0 8rpx 25rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 10rpx rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
  font-family: 'Georgia', serif;
}

.btn-cancel {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
  color: #d4af37;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.btn-cancel:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
}

.btn-confirm {
  background: linear-gradient(135deg, #d4af37 0%, #b89628 100%);
  color: #2c1810;
  border: 2rpx solid rgba(255, 215, 0, 0.4);
  text-shadow: 0 1rpx 3rpx rgba(255, 255, 255, 0.3);
}

.btn-confirm:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
}
