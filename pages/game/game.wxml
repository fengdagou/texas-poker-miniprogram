<!--pages/game/game.wxml-->
<view class="game-container">
  <!-- 荷官区域 -->
  <view class="dealer-area" wx:if="{{isDealing}}">
    <view class="dealer-avatar">
      <text class="dealer-emoji">👩‍🦳</text>
    </view>
    <view class="dealer-name">Victoria</view>
    <view class="dealer-message">{{dealingMessage}}</view>
    <!-- 发牌动画 -->
    <view class="dealing-animation">
      <view class="flying-card card-1"></view>
      <view class="flying-card card-2"></view>
      <view class="flying-card card-3"></view>
    </view>
  </view>
  
  <!-- 顶部信息栏 -->
  <view class="top-bar">
    <view class="room-info">
      <text wx:if="{{roomId}}">房间：{{roomId}}</text>
      <text wx:else>人机对战</text>
    </view>
    <view class="pot-info">
      <text class="pot-label">底池：</text>
      <text class="pot-amount">{{pot || 0}}</text>
    </view>
    <view class="my-status">
      <text class="my-chips-top">💰 {{myChips || 0}}</text>
      <text wx:if="{{myCurrentBet > 0}}" class="my-bet-top">已下注：{{myCurrentBet}}</text>
    </view>
  </view>

  <!-- 对手区域 -->
  <view class="opponents-area">
    <view 
      class="player {{player.isBot ? 'bot' : ''}} {{playerIndex === currentPlayerIndex ? 'active' : ''}}"
      wx:for="{{players}}"
      wx:key="name"
      wx:if="{{playerIndex !== myIndex}}"
      wx:for-item="player"
      wx:for-index="playerIndex"
    >
      <view class="player-avatar">
        <text>{{player.isBot ? '🤖' : '👤'}}</text>
      </view>
      <view class="player-name">{{player.name}}</view>
      <view class="player-chips">💰 {{player.chips || 0}}</view>
      <view class="player-bet" wx:if="{{player.currentBet > 0}}">下注：{{player.currentBet}}</view>
      <view class="player-action" wx:if="{{player.lastAction}}">{{player.lastAction}}</view>
      <view class="player-cards cards-hidden" wx:if="{{!player.isFolded}}">
        <view class="card back"></view>
        <view class="card back"></view>
      </view>
      <view class="player-folded" wx:if="{{player.isFolded}}">弃牌</view>
    </view>
  </view>

  <!-- 公共牌区域 -->
  <view class="community-area">
    <view class="community-cards">
      <view 
        class="card {{getSuitClass(card.suit)}} {{getSuitColorClass(card.suit)}}"
        wx:for="{{communityCards}}"
        wx:key="index"
        wx:for-item="card"
      >
        <text wx:if="{{card}}" class="card-rank {{getSuitColorClass(card.suit)}}">{{card.rank}}{{card.suit}}</text>
      </view>
      <view class="card empty" wx:if="{{communityCards.length < 5}}"></view>
      <view class="card empty" wx:if="{{communityCards.length < 4}}"></view>
      <view class="card empty" wx:if="{{communityCards.length < 3}}"></view>
    </view>
    <view class="stage-label">{{stageText}}</view>
  </view>

  <!-- 我的手牌区域 -->
  <view class="my-area">
    <view class="my-cards">
      <view class="card {{getSuitClass(card.suit)}}" wx:for="{{myHand}}" wx:key="*this" wx:for-item="card">
        <text class="card-rank" style="color: {{card.suit === '♥' || card.suit === '♦' ? '#FF0000' : '#000000'}}">{{card.rank}}{{card.suit}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮区域 -->
  <view class="action-area" wx:if="{{isMyTurn && gameStage < 5}}">
    <!-- 快捷下注按钮 -->
    <view class="bet-presets">
      <view class="bet-preset-btn {{betAmount === 20 ? 'active' : ''}}" bindtap="setBetAmount" data-amount="20">20</view>
      <view class="bet-preset-btn {{betAmount === 50 ? 'active' : ''}}" bindtap="setBetAmount" data-amount="50">50</view>
      <view class="bet-preset-btn {{betAmount === 100 ? 'active' : ''}}" bindtap="setBetAmount" data-amount="100">100</view>
      <view class="bet-preset-btn {{betAmount === 200 ? 'active' : ''}}" bindtap="setBetAmount" data-amount="200">200</view>
    </view>
    
    <!-- 滑动条 -->
    <view class="bet-slider">
      <slider 
        min="{{minBet}}"
        max="{{maxBet}}"
        value="{{betAmount}}"
        block-size="24"
        activeColor="#f39c12"
        bindchange="onBetChange"
      />
      <text class="bet-amount" wx:if="{{betAmount}}">{{betAmount}}</text>
    </view>
    
    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn-fold" bindtap="fold">弃牌</button>
      <button class="btn-check" bindtap="check" wx:if="{{canCheck}}">过牌</button>
      <button class="btn-call" bindtap="call" wx:if="{{!canCheck}}">跟注 {{toCall || 0}}</button>
      <button class="btn-raise" bindtap="raise">加注</button>
      <button class="btn-allin" bindtap="allIn">ALL IN</button>
    </view>
  </view>

  <!-- 等待提示 -->
  <view class="waiting-mask" wx:if="{{!isMyTurn && gameStage < 6}}">
    <text>等待其他玩家操作...</text>
  </view>

  <!-- 出牌提示 -->
  <view class="action-hint" wx:if="{{isMyTurn && gameStage < 5}}">
    <view class="hint-content">
      <text class="hint-icon">🎯</text>
      <text class="hint-text">轮到你出牌</text>
    </view>
    <view class="hint-actions">
      <text class="hint-item" wx:if="{{canCheck}}">💡 可以过牌</text>
      <text class="hint-item" wx:else>💰 跟注 {{toCall || 0}}</text>
      <text class="hint-item">🎲 或加注</text>
    </view>
  </view>

  <!-- 结算弹窗 -->
  <view class="result-modal" wx:if="{{showResult}}">
    <view class="result-content">
      <view class="result-title">{{winnerText}}</view>
      <view class="result-hand" wx:if="{{winnerHand}}">
        <text>牌型：{{winnerHand.typeName}}</text>
      </view>
      <view class="result-amount">+{{winAmount}}</view>
      
      <!-- 公共牌 -->
      <view class="community-cards-result">
        <view class="community-title">🎴 公共牌</view>
        <view class="community-list">
          <view class="card {{getSuitClass(card.suit)}} {{getSuitColorClass(card.suit)}}" wx:for="{{communityCards}}" wx:key="*this" wx:for-item="card">
            <text class="card-rank {{getSuitColorClass(card.suit)}}">{{card.rank}}{{card.suit}}</text>
          </view>
          <view class="card empty" wx:if="{{communityCards.length < 5}}"></view>
          <view class="card empty" wx:if="{{communityCards.length < 4}}"></view>
          <view class="card empty" wx:if="{{communityCards.length < 3}}"></view>
        </view>
      </view>
      
      <!-- 所有玩家手牌 -->
      <view class="all-hands-title">📋 玩家手牌</view>
      <view class="all-hands-list">
        <view class="player-hand-item" wx:for="{{allPlayers}}" wx:key="id" wx:for-item="player">
          <view class="player-hand-name">{{player.name}}</view>
          <view class="player-hand-cards">
            <view class="card {{getSuitClass(card.suit)}} {{getSuitColorClass(card.suit)}}" wx:for="{{player.hand}}" wx:key="*this" wx:for-item="card">
              <text class="card-rank {{getSuitColorClass(card.suit)}}">{{card.rank}}{{card.suit}}</text>
            </view>
            <text wx:if="{{player.hand.length === 0}}" class="no-hand">未发牌</text>
          </view>
          <view class="player-hand-fold" wx:if="{{player.isFolded}}">（已弃牌）</view>
        </view>
      </view>
      
      <view class="result-buttons">
        <button class="btn-next" bindtap="nextGame">下一局</button>
        <button class="btn-exit" bindtap="exitGame">退出</button>
      </view>
    </view>
  </view>
</view>
