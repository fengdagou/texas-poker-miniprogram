/* pages/game/game.wxss - 古典风格 */

/* ========== 全局花色颜色 - 放在最前面 ========== */
.suit-red {
  color: red !important;
}
.suit-red .card-rank {
  color: red !important;
}
.suit-black {
  color: black !important;
}
.suit-black .card-rank {
  color: black !important;
}

/* ========== 古典主题变量 ========== */
.game-container {
  min-height: 100vh;
  background: 
    repeating-linear-gradient(
      90deg,
      rgba(139, 69, 19, 0.1) 0px,
      rgba(139, 69, 19, 0.1) 2px,
      transparent 2px,
      transparent 4px
    ),
    linear-gradient(135deg, #2c1810 0%, #1a0f0a 50%, #2c1810 100%);
  position: relative;
  overflow: hidden;
}

/* 古典边框装饰 */
.game-container::before {
  content: '';
  position: fixed;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.3);
  border-radius: 20rpx;
  pointer-events: none;
  z-index: 1;
}

/* 角落装饰 */
.game-container::after {
  content: '♠ ♥ ♦ ♣';
  position: fixed;
  top: 20rpx;
  right: 30rpx;
  color: rgba(212, 175, 55, 0.2);
  font-size: 40rpx;
  letter-spacing: 10rpx;
  pointer-events: none;
  z-index: 2;
}

/* ========== 荷官区域 ========== */
.dealer-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100vh;
  background: rgba(26, 15, 10, 0.98);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2000;
  animation: dealerFadeIn 0.5s ease;
}

@keyframes dealerFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.dealer-avatar {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #f5deb3 0%, #d2b48c 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
  margin-bottom: 30rpx;
  border: 6rpx solid rgba(212, 175, 55, 0.6);
  box-shadow: 
    0 10rpx 40rpx rgba(0, 0, 0, 0.5),
    0 0 60rpx rgba(212, 175, 55, 0.4);
  position: relative;
}

.dealer-avatar::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 215, 0, 0.3);
  animation: rotate 10s linear infinite;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.dealer-name {
  font-size: 48rpx;
  color: #ffd700;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 15rpx rgba(255, 215, 0, 0.5);
  font-family: 'Georgia', serif;
  letter-spacing: 5rpx;
}

.dealer-message {
  font-size: 32rpx;
  color: #f0c850;
  margin-bottom: 60rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
  animation: messagePulse 1.5s ease-in-out infinite;
}

@keyframes messagePulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.05);
  }
}

/* 发牌动画 */
.dealing-animation {
  position: relative;
  width: 600rpx;
  height: 400rpx;
}

.flying-card {
  position: absolute;
  width: 100rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #f5f5dc 0%, #e8e4c9 100%);
  border-radius: 12rpx;
  border: 3rpx solid rgba(139, 69, 19, 0.4);
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.5);
  opacity: 0;
}

.flying-card::before {
  content: '♠';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: rgba(139, 69, 19, 0.3);
  font-size: 60rpx;
}

.card-1 {
  animation: flyCard1 2s ease-in-out infinite;
}

.card-2 {
  animation: flyCard2 2s ease-in-out infinite 0.3s;
}

.card-3 {
  animation: flyCard3 2s ease-in-out infinite 0.6s;
}

@keyframes flyCard1 {
  0% {
    opacity: 0;
    transform: translate(-150rpx, -100rpx) rotate(-30deg);
  }
  20% {
    opacity: 1;
  }
  50% {
    transform: translate(0, 0) rotate(0deg);
  }
  80% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translate(150rpx, 100rpx) rotate(30deg);
  }
}

@keyframes flyCard2 {
  0% {
    opacity: 0;
    transform: translate(0, -120rpx) rotate(-20deg);
  }
  20% {
    opacity: 1;
  }
  50% {
    transform: translate(0, 0) rotate(0deg);
  }
  80% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translate(0, 120rpx) rotate(20deg);
  }
}

@keyframes flyCard3 {
  0% {
    opacity: 0;
    transform: translate(150rpx, -100rpx) rotate(-30deg);
  }
  20% {
    opacity: 1;
  }
  50% {
    transform: translate(0, 0) rotate(0deg);
  }
  80% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translate(-150rpx, 100rpx) rotate(30deg);
  }
}

/* ========== 顶部信息栏 ========== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(180deg, rgba(62, 39, 25, 0.95) 0%, rgba(44, 24, 16, 0.9) 100%);
  border-bottom: 2rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
  flex-wrap: wrap;
  gap: 15rpx;
  position: relative;
  z-index: 10;
}

.room-info {
  color: #d4af37;
  font-size: 26rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  font-family: 'Georgia', serif;
}

.pot-info {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.6) 0%, rgba(62, 39, 25, 0.8) 100%);
  padding: 10rpx 30rpx;
  border-radius: 25rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.5);
  box-shadow: 
    0 4rpx 15rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 10rpx rgba(212, 175, 55, 0.1);
}

.pot-label {
  color: #f0c850;
  font-size: 26rpx;
  font-weight: bold;
}

.pot-amount {
  color: #ffd700;
  font-size: 32rpx;
  font-weight: bold;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.my-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.my-chips-top {
  color: #ffd700;
  font-size: 30rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 10rpx rgba(255, 215, 0, 0.3);
}

.my-bet-top {
  color: #f0c850;
  font-size: 24rpx;
  font-weight: bold;
}

/* ========== 对手区域 - 缩小 ========== */
.opponents-area {
  padding: 30rpx 20rpx;
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  gap: 20rpx;
  position: relative;
  z-index: 5;
}

.player {
  position: relative;
  text-align: center;
  padding: 15rpx;
  border-radius: 15rpx;
  transition: all 0.3s ease;
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.6) 0%, rgba(44, 24, 16, 0.8) 100%);
  border: 2rpx solid rgba(212, 175, 55, 0.2);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
}

.player.active {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.3) 0%, rgba(139, 69, 19, 0.5) 100%);
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.5);
  border-color: rgba(212, 175, 55, 0.6);
  transform: scale(1.03);
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #8b4513 0%, #5c3317 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin: 0 auto 10rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.4);
}

.player-name {
  color: #f0c850;
  font-size: 22rpx;
  margin-bottom: 5rpx;
  font-weight: bold;
}

.player-chips {
  color: #ffd700;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.player-bet {
  color: #f0c850;
  font-size: 26rpx;
  font-weight: bold;
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.7) 0%, rgba(62, 39, 25, 0.9) 100%);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 8rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.3);
}

.player-action {
  position: absolute;
  top: -15rpx;
  right: -15rpx;
  background: linear-gradient(135deg, #8b0000 0%, #5c0000 100%);
  color: #ffd700;
  padding: 10rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: bold;
  animation: popIn 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  border: 2rpx solid rgba(212, 175, 55, 0.5);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.5);
}

.player-cards {
  display: flex;
  gap: 10rpx;
  justify-content: center;
  margin-top: 20rpx;
}

.player-folded {
  color: #8b0000;
  font-size: 26rpx;
  font-weight: bold;
  margin-top: 15rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

@keyframes popIn {
  from {
    transform: scale(0) rotate(-180deg);
    opacity: 0;
  }
  to {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

/* ========== 公共牌区域 - 适中大小 ========== */
.community-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 25rpx;
  background: linear-gradient(135deg, rgba(44, 24, 16, 0.8) 0%, rgba(62, 39, 25, 0.6) 100%);
  margin: 20rpx 30rpx;
  border-radius: 25rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.5);
  position: relative;
  z-index: 5;
}

/* 古典花纹装饰 */
.community-area::before {
  content: '♦ ♥ ♣ ♠';
  position: absolute;
  top: 15rpx;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(212, 175, 55, 0.15);
  font-size: 30rpx;
  letter-spacing: 30rpx;
}

.community-cards {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 25rpx;
  margin-top: 20rpx;
  padding: 25rpx 35rpx;
  background: linear-gradient(135deg, rgba(25, 15, 10, 0.9) 0%, rgba(44, 24, 16, 0.8) 100%);
  border-radius: 25rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.2);
  box-shadow: inset 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
}

.card {
  width: 85rpx;
  height: 125rpx;
  background: linear-gradient(135deg, #f5f5dc 0%, #e8e4c9 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  box-shadow: 
    0 6rpx 15rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 10rpx rgba(255, 255, 255, 0.5);
  position: relative;
  border: 2rpx solid rgba(139, 69, 19, 0.3);
}

/* 古典卡牌背面设计 */
.card.back {
  background: 
    repeating-linear-gradient(
      45deg,
      #8b0000 0px,
      #8b0000 8px,
      #5c0000 8px,
      #5c0000 16px
    );
  border: 3rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: 
    0 6rpx 15rpx rgba(0, 0, 0, 0.5),
    inset 0 0 20rpx rgba(0, 0, 0, 0.3);
}

.card.back::before {
  content: '♠';
  position: absolute;
  color: rgba(212, 175, 55, 0.3);
  font-size: 60rpx;
}

.card.empty {
  background: rgba(245, 245, 220, 0.1);
  border: 3rpx dashed rgba(212, 175, 55, 0.3);
  box-shadow: inset 0 4rpx 15rpx rgba(0, 0, 0, 0.3);
}

.card-rank {
  display: block;
  z-index: 2;
}

/* ========== 花色颜色 - 最高优先级 ========== */
/* 红色花色：红桃♥ 方块♦ */
.suit-red {
  color: red !important;
}
.suit-red .card-rank {
  color: red !important;
}
.card.hearts {
  color: red !important;
}
.card.hearts .card-rank {
  color: red !important;
}
.card.diamonds {
  color: red !important;
}
.card.diamonds .card-rank {
  color: red !important;
}
text.hearts,
text.diamonds,
.card-rank.hearts,
.card-rank.diamonds,
text.suit-red,
.card-rank.suit-red {
  color: red !important;
}

/* 黑色花色：黑桃♠ 梅花♣ */
.suit-black {
  color: black !important;
}
.suit-black .card-rank {
  color: black !important;
}
.card.spades {
  color: black !important;
}
.card.spades .card-rank {
  color: black !important;
}
.card.clubs {
  color: black !important;
}
.card.clubs .card-rank {
  color: black !important;
}
text.spades,
text.clubs,
.card-rank.spades,
.card-rank.clubs,
text.suit-black,
.card-rank.suit-black {
  color: black !important;
}

.stage-label {
  color: #d4af37;
  font-size: 32rpx;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 5rpx;
  text-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.5);
  font-family: 'Georgia', serif;
  padding: 10rpx 30rpx;
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.4);
}

/* ========== 我的手牌区域 ========== */
/* ========== 我的手牌区域 - 提高位置 ========== */
.my-area {
  position: fixed;
  bottom: 280rpx;
  left: 0;
  right: 0;
  background: transparent;
  padding: 15rpx;
  z-index: 50;
  pointer-events: none;
}

.my-cards {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  margin-bottom: 0;
}

.my-cards .card {
  width: 75rpx;
  height: 110rpx;
  font-size: 38rpx;
  box-shadow: 
    0 6rpx 20rpx rgba(0, 0, 0, 0.6),
    inset 0 2rpx 10rpx rgba(255, 255, 255, 0.6);
  background: linear-gradient(135deg, #f5f5dc 0%, #e8e4c9 100%);
  border-radius: 10rpx;
  border: 2rpx solid rgba(139, 69, 19, 0.4);
}

/* ========== 操作按钮区域 - 紧凑设计 ========== */
.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, rgba(44, 24, 16, 0.95) 0%, rgba(26, 15, 10, 0.98) 100%);
  padding: 12rpx 15rpx;
  padding-bottom: 20rpx;
  z-index: 100;
  border-top: 2rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: 0 -5rpx 25rpx rgba(0, 0, 0, 0.5);
  max-height: 260rpx;
}

.bet-slider {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  padding: 0 10rpx;
}

.bet-slider slider {
  flex: 1;
  height: 36rpx;
}

.bet-amount {
  color: #ffd700;
  font-size: 26rpx;
  font-weight: bold;
  min-width: 70rpx;
  text-align: right;
  text-shadow: 0 2rpx 8rpx rgba(255, 215, 0, 0.4);
}

/* 快捷下注按钮 - 紧凑设计 */
.bet-presets {
  display: flex;
  gap: 8rpx;
  justify-content: center;
  margin-bottom: 12rpx;
  padding: 0 10rpx;
}

.bet-preset-btn {
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
  border: 2rpx solid rgba(212, 175, 55, 0.4);
  color: #d4af37;
  font-size: 20rpx;
  font-weight: bold;
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.4);
  transition: all 0.3s ease;
}

.bet-preset-btn.active {
  background: linear-gradient(135deg, #d4af37 0%, #b89628 100%);
  color: #2c1810;
  border-color: #ffd700;
  box-shadow: 
    0 6rpx 20rpx rgba(212, 175, 55, 0.5),
    inset 0 2rpx 10rpx rgba(255, 255, 255, 0.3);
  transform: translateY(-3rpx);
}

/* 操作按钮 - 古典风格 */
.action-buttons {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}

.action-buttons button {
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
  border: none;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.action-buttons button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.action-buttons button:active::before {
  left: 100%;
}

.btn-fold {
  background: linear-gradient(135deg, #8b0000 0%, #5c0000 100%);
  color: #ffd700;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.btn-fold:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
}

.btn-check {
  background: linear-gradient(135deg, #2e5c8a 0%, #1a3a5c 100%);
  color: #f0c850;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.btn-check:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
}

.btn-call {
  background: linear-gradient(135deg, #2d5016 0%, #1a3009 100%);
  color: #ffd700;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.btn-call:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
}

.btn-raise {
  background: linear-gradient(135deg, #d4af37 0%, #b89628 100%);
  color: #2c1810;
  border: 2rpx solid rgba(255, 215, 0, 0.5);
}

.btn-raise:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
}

.btn-allin {
  background: linear-gradient(135deg, #8b0000 0%, #5c0000 50%, #8b0000 100%);
  color: #ffd700;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.6);
  animation: pulse 2s ease-in-out infinite;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 
      0 6rpx 20rpx rgba(139, 0, 0, 0.4),
      0 0 30rpx rgba(212, 175, 55, 0.3);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 
      0 10rpx 30rpx rgba(139, 0, 0, 0.6),
      0 0 50rpx rgba(212, 175, 55, 0.5);
  }
}

/* ========== 等待提示 ========== */
.waiting-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 400rpx;
  background: rgba(26, 15, 10, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #d4af37;
  font-size: 36rpx;
  z-index: 50;
  font-weight: bold;
  text-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.5);
  backdrop-filter: blur(5rpx);
}

/* ========== 出牌提示 ========== */
.action-hint {
  position: fixed;
  top: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.85) 0%, rgba(44, 24, 16, 0.9) 100%);
  border: 2rpx solid rgba(212, 175, 55, 0.5);
  border-radius: 20rpx;
  padding: 15rpx 30rpx;
  z-index: 1500;
  box-shadow: 0 5rpx 30rpx rgba(0, 0, 0, 0.5);
  animation: hintPulse 2s ease-in-out infinite;
  min-width: auto;
  text-align: center;
  backdrop-filter: blur(5rpx);
}

@keyframes hintPulse {
  0%, 100% {
    transform: translateX(-50%) scale(1);
    opacity: 0.9;
  }
  50% {
    transform: translateX(-50%) scale(1.02);
    opacity: 1;
  }
}

.hint-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 0;
}

.hint-icon {
  font-size: 36rpx;
  animation: bounce 1s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-5rpx);
  }
}

.hint-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 0 2rpx 8rpx rgba(255, 215, 0, 0.5);
  font-family: 'Georgia', serif;
  letter-spacing: 2rpx;
}

.hint-actions {
  display: none;
}

/* ========== 结算弹窗 ========== */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 15, 10, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.result-content {
  background: linear-gradient(135deg, #2c1810 0%, #1a0f0a 50%, #2c1810 100%);
  border-radius: 40rpx;
  padding: 70rpx;
  text-align: center;
  width: 85%;
  max-width: 650rpx;
  border: 4rpx solid rgba(212, 175, 55, 0.5);
  box-shadow: 
    0 20rpx 60rpx rgba(0, 0, 0, 0.7),
    inset 0 0 50rpx rgba(139, 69, 19, 0.3);
  position: relative;
}

/* 古典角饰 */
.result-content::before {
  content: '♠';
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  color: rgba(212, 175, 55, 0.3);
  font-size: 50rpx;
}

.result-content::after {
  content: '♣';
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  color: rgba(212, 175, 55, 0.3);
  font-size: 50rpx;
}

.result-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 40rpx;
  text-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.5);
  font-family: 'Georgia', serif;
  letter-spacing: 5rpx;
}

.result-hand {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.7) 0%, rgba(44, 24, 16, 0.9) 100%);
  padding: 25rpx 40rpx;
  border-radius: 20rpx;
  margin-bottom: 35rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: inset 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.result-hand text {
  color: #f0c850;
  font-size: 36rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.3);
}

.result-amount {
  font-size: 64rpx;
  font-weight: bold;
  color: #27ae60;
  margin-bottom: 40rpx;
  text-shadow: 0 4rpx 20rpx rgba(39, 174, 96, 0.5);
  font-family: 'Georgia', serif;
}

/* 公共牌区域 - 结算弹窗内 */
.community-cards-result {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.5) 0%, rgba(44, 24, 16, 0.7) 100%);
  border: 2rpx solid rgba(212, 175, 55, 0.3);
  padding: 25rpx;
  border-radius: 20rpx;
  margin-bottom: 35rpx;
  box-shadow: inset 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.community-title {
  font-size: 30rpx;
  color: #d4af37;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.3);
  font-family: 'Georgia', serif;
}

.community-list {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  flex-wrap: wrap;
}

.community-list .card {
  width: 75rpx;
  height: 110rpx;
  font-size: 40rpx;
}

/* 所有玩家手牌 */
.all-hands-title {
  font-size: 32rpx;
  color: #d4af37;
  font-weight: bold;
  margin-bottom: 25rpx;
  text-align: center;
  text-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.3);
  font-family: 'Georgia', serif;
}

.all-hands-list {
  background: rgba(44, 24, 16, 0.5);
  padding: 25rpx;
  border-radius: 20rpx;
  margin-bottom: 35rpx;
  max-height: 450rpx;
  overflow-y: auto;
  border: 2rpx solid rgba(212, 175, 55, 0.2);
}

.player-hand-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.5) 0%, rgba(44, 24, 16, 0.7) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.15);
}

.player-hand-item:last-child {
  margin-bottom: 0;
}

.player-hand-name {
  font-size: 28rpx;
  color: #ffd700;
  font-weight: bold;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.player-hand-cards {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}

.player-hand-cards .card {
  width: 65rpx;
  height: 95rpx;
  font-size: 36rpx;
}

.no-hand {
  color: #6b5345;
  font-size: 26rpx;
}

.player-hand-fold {
  font-size: 24rpx;
  color: #8b0000;
  margin-top: 10rpx;
  font-weight: bold;
}

/* 按钮 - 结算弹窗 */
.result-buttons {
  display: flex;
  gap: 20rpx;
}

.result-buttons button {
  flex: 1;
  padding: 25rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 
    0 8rpx 25rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 10rpx rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.btn-next {
  background: linear-gradient(135deg, #27ae60 0%, #1e8449 100%);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.btn-next:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
}

.btn-exit {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
  color: #d4af37;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.btn-exit:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
}

/* ========== 滚动条样式 ========== */
.all-hands-list::-webkit-scrollbar {
  width: 8rpx;
}

.all-hands-list::-webkit-scrollbar-track {
  background: rgba(44, 24, 16, 0.5);
  border-radius: 10rpx;
}

.all-hands-list::-webkit-scrollbar-thumb {
  background: rgba(212, 175, 55, 0.4);
  border-radius: 10rpx;
}

.all-hands-list::-webkit-scrollbar-thumb:hover {
  background: rgba(212, 175, 55, 0.6);
}
