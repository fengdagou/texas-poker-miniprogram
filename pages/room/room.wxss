/* pages/room/room.wxss - 古典风格 */

.room-container {
  min-height: 100vh;
  background: 
    repeating-linear-gradient(
      90deg,
      rgba(139, 69, 19, 0.08) 0px,
      rgba(139, 69, 19, 0.08) 2px,
      transparent 2px,
      transparent 4px
    ),
    linear-gradient(135deg, #2c1810 0%, #1a0f0a 50%, #2c1810 100%);
  padding: 30rpx;
  box-sizing: border-box;
  position: relative;
}

.room-container::before {
  content: '';
  position: fixed;
  top: 15rpx;
  left: 15rpx;
  right: 15rpx;
  bottom: 15rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.25);
  border-radius: 25rpx;
  pointer-events: none;
  z-index: 1;
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
  padding: 35rpx;
  border-radius: 25rpx;
  margin-bottom: 40rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.35);
  box-shadow: 
    0 8rpx 30rpx rgba(0, 0, 0, 0.5),
    inset 0 2rpx 15rpx rgba(212, 175, 55, 0.1);
  position: relative;
  z-index: 5;
}

.room-label {
  color: #d4af37;
  font-size: 30rpx;
  margin-right: 20rpx;
  font-weight: bold;
}

.room-number {
  color: #ffd700;
  font-size: 44rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
  text-shadow: 0 2rpx 15rpx rgba(255, 215, 0, 0.4);
  font-family: 'Georgia', serif;
}

.room-status {
  background: linear-gradient(135deg, #27ae60 0%, #1e8449 100%);
  color: white;
  padding: 12rpx 35rpx;
  border-radius: 25rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.3);
}

.players-section {
  margin-bottom: 40rpx;
  position: relative;
  z-index: 5;
}

.section-title {
  color: #ffd700;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 25rpx;
  text-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.3);
  font-family: 'Georgia', serif;
}

.player-list {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.6) 0%, rgba(44, 24, 16, 0.8) 100%);
  border-radius: 25rpx;
  padding: 25rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.25);
  box-shadow: 
    0 8rpx 30rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 15rpx rgba(212, 175, 55, 0.08);
}

.player-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  border-bottom: 2rpx solid rgba(212, 175, 55, 0.15);
}

.player-item:last-child {
  border-bottom: none;
}

.player-avatar {
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #8b4513 0%, #5c3317 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 25rpx;
  border: 4rpx solid rgba(212, 175, 55, 0.35);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
}

.player-info {
  flex: 1;
}

.player-name {
  color: #ffd700;
  font-size: 32rpx;
  margin-bottom: 10rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.player-coins {
  color: #f0c850;
  font-size: 28rpx;
}

.host-tag,
.ready-tag {
  background: linear-gradient(135deg, #d4af37 0%, #b89628 100%);
  color: #2c1810;
  padding: 8rpx 20rpx;
  border-radius: 15rpx;
  font-size: 24rpx;
  font-weight: bold;
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}

.ready-tag {
  background: linear-gradient(135deg, #27ae60 0%, #1e8449 100%);
  color: white;
  border-color: rgba(255, 255, 255, 0.2);
}

.empty-slot {
  padding: 35rpx;
  text-align: center;
  color: #6b5345;
  font-size: 28rpx;
  border: 3rpx dashed rgba(212, 175, 55, 0.25);
  border-radius: 20rpx;
  margin-top: 15rpx;
  background: rgba(44, 24, 16, 0.4);
}

.action-section {
  margin-bottom: 40rpx;
  position: relative;
  z-index: 5;
}

.action-section button {
  width: 100%;
  padding: 35rpx;
  margin-bottom: 25rpx;
  border-radius: 25rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
  box-shadow: 
    0 8rpx 25rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 10rpx rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
  font-family: 'Georgia', serif;
}

.btn-start {
  background: linear-gradient(135deg, #d4af37 0%, #b89628 100%);
  color: #2c1810;
  border: 2rpx solid rgba(255, 215, 0, 0.4);
  text-shadow: 0 1rpx 3rpx rgba(255, 255, 255, 0.3);
}

.btn-start:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
}

.btn-start[disabled] {
  background: linear-gradient(135deg, #6b5345 0%, #4a3728 100%);
  color: #8b6f5a;
  border-color: rgba(212, 175, 55, 0.15);
}

.btn-invite {
  background: linear-gradient(135deg, #2e5c8a 0%, #1a3a5c 100%);
  color: #f0c850;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.btn-invite:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
}

.btn-leave {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
  color: #d4af37;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.btn-leave:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
}

.tips-section {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.5) 0%, rgba(44, 24, 16, 0.7) 100%);
  border-radius: 25rpx;
  padding: 35rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.2);
  position: relative;
  z-index: 5;
}

.tip-item {
  color: #d4af37;
  font-size: 28rpx;
  margin-bottom: 18rpx;
  line-height: 1.7;
  opacity: 0.85;
}

.tip-item:last-child {
  margin-bottom: 0;
}
