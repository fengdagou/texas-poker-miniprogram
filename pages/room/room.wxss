/* pages/room/room.wxss */
.room-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 30rpx;
  box-sizing: border-box;
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
}

.room-label {
  color: #8892b0;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.room-number {
  color: #ffd700;
  font-size: 40rpx;
  font-weight: bold;
  letter-spacing: 5rpx;
}

.room-status {
  background: #27ae60;
  color: white;
  padding: 10rpx 30rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.players-section {
  margin-bottom: 40rpx;
}

.section-title {
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.player-list {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 20rpx;
}

.player-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.player-item:last-child {
  border-bottom: none;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.player-info {
  flex: 1;
}

.player-name {
  color: white;
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.player-coins {
  color: #ffd700;
  font-size: 26rpx;
}

.player-role,
.player-ready {
  margin-left: 10rpx;
}

.host-tag,
.ready-tag {
  background: #f39c12;
  color: white;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
}

.ready-tag {
  background: #27ae60;
}

.empty-slot {
  padding: 30rpx;
  text-align: center;
  color: #5a6a8a;
  font-size: 28rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.1);
  border-radius: 15rpx;
  margin-top: 10rpx;
}

.action-section {
  margin-bottom: 40rpx;
}

.action-section button {
  width: 100%;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.btn-start {
  background: linear-gradient(135deg, #f39c12 0%, #e74c3c 100%);
  color: white;
}

.btn-start[disabled] {
  background: #5a6a8a;
  color: #8892b0;
}

.btn-invite {
  background: #3498db;
  color: white;
}

.btn-leave {
  background: rgba(255, 255, 255, 0.1);
  color: white;
}

.tips-section {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
}

.tip-item {
  color: #8892b0;
  font-size: 26rpx;
  margin-bottom: 15rpx;
  line-height: 1.6;
}

.tip-item:last-child {
  margin-bottom: 0;
}
