/* 排行榜页面样式 - 古典风格 */

.leaderboard-container {
  padding: 25rpx;
  min-height: 100vh;
  background: 
    repeating-linear-gradient(
      90deg,
      rgba(139, 69, 19, 0.08) 0px,
      rgba(139, 69, 19, 0.08) 2px,
      transparent 2px,
      transparent 4px
    ),
    linear-gradient(180deg, #2c1810 0%, #1a0f0a 100%);
  position: relative;
}

.leaderboard-container::before {
  content: '';
  position: fixed;
  top: 15rpx;
  left: 15rpx;
  right: 15rpx;
  bottom: 15rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.25);
  border-radius: 25rpx;
  pointer-events: none;
  z-index: 1;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 5;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 35rpx;
  text-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.5);
  font-family: 'Georgia', serif;
  letter-spacing: 8rpx;
}

.tabs {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 25rpx;
}

.tab {
  padding: 18rpx 45rpx;
  border-radius: 35rpx;
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.7) 0%, rgba(44, 24, 16, 0.85) 100%);
  color: #d4af37;
  font-size: 30rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.25);
  box-shadow: 
    0 4rpx 15rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 10rpx rgba(212, 175, 55, 0.08);
  transition: all 0.3s ease;
  font-family: 'Georgia', serif;
  font-weight: bold;
}

.tab.active {
  background: linear-gradient(135deg, #d4af37 0%, #b89628 100%);
  color: #2c1810;
  border-color: rgba(255, 215, 0, 0.5);
  box-shadow: 
    0 6rpx 20rpx rgba(212, 175, 55, 0.4),
    inset 0 2rpx 10rpx rgba(255, 255, 255, 0.3);
  transform: translateY(-3rpx);
}

/* 我的排名 */
.my-rank {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
  padding: 35rpx;
  border-radius: 25rpx;
  margin-bottom: 35rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: 
    0 10rpx 35rpx rgba(0, 0, 0, 0.5),
    inset 0 2rpx 15rpx rgba(212, 175, 55, 0.1);
  position: relative;
  z-index: 5;
}

.rank-number {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #d4af37;
  margin-right: 25rpx;
  border: 3rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
  font-family: 'Georgia', serif;
}

.rank-number.top {
  background: linear-gradient(135deg, #d4af37 0%, #b89628 100%);
  color: #2c1810;
  border-color: #ffd700;
  box-shadow: 
    0 4rpx 20rpx rgba(212, 175, 55, 0.5),
    0 0 30rpx rgba(255, 215, 0, 0.3);
}

.rank-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 25rpx;
  border: 4rpx solid rgba(212, 175, 55, 0.4);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.4);
  background: linear-gradient(135deg, #8b4513 0%, #5c3317 100%);
}

.rank-avatar image {
  width: 100%;
  height: 100%;
}

.rank-info {
  flex: 1;
}

.rank-name {
  font-size: 34rpx;
  color: #ffd700;
  font-weight: bold;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  font-family: 'Georgia', serif;
}

.rank-score {
  font-size: 28rpx;
  color: #f0c850;
  opacity: 0.9;
}

.rank-trend {
  font-size: 36rpx;
}

.rank-trend.up {
  color: #27ae60;
  text-shadow: 0 2rpx 10rpx rgba(39, 174, 96, 0.4);
}

.rank-trend.down {
  color: #c0392b;
  text-shadow: 0 2rpx 10rpx rgba(192, 57, 43, 0.4);
}

.rank-trend.same {
  color: #6b5345;
}

/* 排行榜列表 */
.rank-list {
  background: linear-gradient(135deg, rgba(62, 39, 25, 0.6) 0%, rgba(44, 24, 16, 0.8) 100%);
  border-radius: 25rpx;
  padding: 25rpx;
  border: 2rpx solid rgba(212, 175, 55, 0.25);
  box-shadow: 
    0 8rpx 30rpx rgba(0, 0, 0, 0.4),
    inset 0 2rpx 15rpx rgba(212, 175, 55, 0.08);
  position: relative;
  z-index: 5;
}

.rank-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 25rpx;
  border-bottom: 2rpx solid rgba(212, 175, 55, 0.15);
}

.rank-item:last-child {
  border-bottom: none;
}

/* 前三名特殊样式 */
.rank-item:nth-child(1) .rank-number {
  background: linear-gradient(135deg, #ffd700 0%, #ffb700 100%);
  color: #2c1810;
  border-color: #fff;
  box-shadow: 
    0 4rpx 20rpx rgba(255, 215, 0, 0.6),
    0 0 30rpx rgba(255, 215, 0, 0.4);
}

.rank-item:nth-child(2) .rank-number {
  background: linear-gradient(135deg, #c0c0c0 0%, #a0a0a0 100%);
  color: #2c1810;
  border-color: #e0e0e0;
  box-shadow: 0 4rpx 20rpx rgba(192, 192, 192, 0.5);
}

.rank-item:nth-child(3) .rank-number {
  background: linear-gradient(135deg, #cd7f32 0%, #b87333 100%);
  color: #fff;
  border-color: #e09050;
  box-shadow: 0 4rpx 20rpx rgba(205, 127, 50, 0.5);
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #6b5345;
  font-size: 32rpx;
  opacity: 0.7;
}
