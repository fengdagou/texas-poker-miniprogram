/* 排行榜页面样式 */

.leaderboard-container {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 30rpx;
}

.tabs {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 20rpx;
}

.tab {
  padding: 15rpx 40rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 28rpx;
}

.tab.active {
  background: #ffd700;
  color: #1a1a2e;
  font-weight: bold;
}

/* 我的排名 */
.my-rank {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.rank-number {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 20rpx;
}

.rank-number.top {
  background: #ffd700;
  color: #1a1a2e;
}

.rank-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  border: 3rpx solid #fff;
}

.rank-avatar image {
  width: 100%;
  height: 100%;
}

.rank-info {
  flex: 1;
}

.rank-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.rank-score {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.rank-trend {
  font-size: 32rpx;
}

.rank-trend.up {
  color: #4ade80;
}

.rank-trend.down {
  color: #f87171;
}

.rank-trend.same {
  color: #9ca3af;
}

/* 排行榜列表 */
.rank-list {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 20rpx;
}

.rank-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 25rpx 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.rank-item:last-child {
  border-bottom: none;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 32rpx;
}
